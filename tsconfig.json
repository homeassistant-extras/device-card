{
  "extends": "@homeassistant-extras/config/tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "paths": {
      "@cards/*": ["./src/cards/*"],
      "@device/*": ["./src/cards/device-card/*"],
      "@integration/*": ["./src/cards/integration-card/*"],
      "@type/*": ["./src/types/*"],
      "@common/*": ["./src/common/*"],
      "@localize/*": ["./src/localize/*"],
      "@theme/*": ["./src/theme/*"],
      "@html/*": ["./src/html/*"],
      "@delegates/*": ["./src/delegates/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
